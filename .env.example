# Used only by the local migration scripts in scripts/supabase (never expose as VITE_*).
SUPABASE_URL=
# Recommended server-side Secret API key (sb_secret_...).
SUPABASE_SECRET_KEY=
# Legacy fallback only: service_role JWT.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=content-images

# Public frontend configuration. These values may be exposed by Vite.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_AUTH_PREVIEW=false
